{
	"name": "obsidian-code",
	"version": "1.0.0",
	"description": "Open and edit code files in a native-feeling CodeMirror editor.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin"
	],
	"author": "",
	"license": "MIT",
