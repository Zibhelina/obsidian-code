		"@replit/codemirror-vim": "^6.3.0",
		"@types/node": "^16.11.6",
		"builtin-modules": "^5.1.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
